<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- Search Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:background="@color/white"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_search_main"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search products…"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textColorHint="@color/medium_gray"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_cart"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_bag"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <!-- BEAUTY -->
        <LinearLayout
            android:id="@+id/btn_cat_beauty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/cat_beauty"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_circle_white"
                    tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_beauty"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- TOPS -->
        <LinearLayout
            android:id="@+id/btn_cat_tops"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_tops"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_tops"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- DRESSES -->
        <LinearLayout
            android:id="@+id/btn_cat_dresses"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_dresses"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_dresses"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BOTTOMS -->
        <LinearLayout
            android:id="@+id/btn_cat_bottoms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bottoms"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_bottoms"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BAGS -->
        <LinearLayout
            android:id="@+id/btn_cat_bags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bags"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_bags"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- ACCESSORIES -->
        <LinearLayout
            android:id="@+id/btn_cat_accessories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bags"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_accessories"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- ACTIVEWEAR -->
        <LinearLayout
            android:id="@+id/btn_cat_activewear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="40dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bottoms"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_activewear"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

    </HorizontalScrollView>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivSaleLogo"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:src="@drawable/banner"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:layout_margin="10dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvNewArrivals"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:scaleType="centerCrop"
                android:textSize="16sp"
                android:text="@string/new_arrivals"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/accent_rose"
                android:gravity="center"
                android:background="@drawable/bg_product_active"
                android:layout_marginHorizontal="10dp"
                tools:ignore="ContentDescription" />

            <!-- Products Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_products_main"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:clipToPadding="false"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_unselected"
        app:itemTextColor="@color/nav_unselected"
        app:itemActiveIndicatorStyle="@android:color/transparent"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>