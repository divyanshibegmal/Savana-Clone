<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <!-- BEAUTY -->
        <LinearLayout
            android:id="@+id/btn_cat_beauty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_beauty"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_beauty"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- TOPS -->
        <LinearLayout
            android:id="@+id/btn_cat_tops"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_tops"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_tops"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- DRESSES -->
        <LinearLayout
            android:id="@+id/btn_cat_dresses"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_dresses"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_dresses"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BOTTOMS -->
        <LinearLayout
            android:id="@+id/btn_cat_bottoms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bottoms"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_bottoms"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- BAGS -->
        <LinearLayout
            android:id="@+id/btn_cat_bags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bags"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_bags"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- ACCESSORIES -->
        <LinearLayout
            android:id="@+id/btn_cat_accessories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bags"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_accessories"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

        <!-- ACTIVEWEAR -->
        <LinearLayout
            android:id="@+id/btn_cat_activewear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/cat_bottoms"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_circle_white"
                android:padding="2dp"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_activewear"
                android:textStyle="bold"
                android:textSize="11sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</HorizontalScrollView>