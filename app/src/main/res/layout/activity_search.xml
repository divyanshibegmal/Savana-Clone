<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Search Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:background="@color/white"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:layout_marginStart="4dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_search_main"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Search products…"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textColorHint="@color/medium_gray"
                android:background="@android:color/transparent"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Browse Categories (shown when no search) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Layout: Categories Browse -->
            <LinearLayout
                android:id="@+id/layout_categories_browse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Popular Searches -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Popular Searches"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:paddingBottom="12dp"/>



                <!-- Row 1 of tags -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView android:id="@+id/tag_tops"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="👕 Tops" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/tag_dresses"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="👗 Dresses" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/tag_makeup"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="💄 Makeup" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <!-- Row 2 of tags -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView android:id="@+id/tag_glasses"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="🕶️ Sunglasses" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/tag_bags"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="👜 Bags" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/tag_sale"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="🔥 Nail Kit" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <!-- Row 3 of tags -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/tag_beauty"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="✨ Beauty" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/tag_activewear"
                        android:layout_width="wrap_content" android:layout_height="36dp"
                        android:text="🏋️ Activewear" android:textSize="13sp" android:textColor="@color/black"
                        android:background="@drawable/bg_category_chip"
                        android:gravity="center" android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <!-- Browse Categories -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Browse Categories"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:paddingTop="24dp"
                    android:paddingBottom="12dp"/>

                <!-- Category Grid 2 cols -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">

                    <LinearLayout android:id="@+id/cat_beauty"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_beauty" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💄" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Beauty" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/cat_tops"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_tops" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👕" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tops" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <LinearLayout android:id="@+id/cat_dresses"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_dress" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👗" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dresses" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/cat_bottoms"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_bottom" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👖" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bottoms" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <LinearLayout android:id="@+id/cat_bags"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_bag" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="👜" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bags" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <LinearLayout android:id="@+id/cat_accessories"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_acc" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginStart="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💍" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Accessories" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:id="@+id/cat_activewear"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
                        android:background="@drawable/bg_product_active" android:orientation="horizontal"
                        android:gravity="center_vertical" android:padding="14dp"
                        android:clickable="true" android:focusable="true" android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🏋️" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Activewear" android:textSize="14sp" android:textStyle="bold"
                            android:textColor="@color/black" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <View android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_weight="1" android:layout_marginStart="6dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Results Section (hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_result_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/dark_gray"
                    android:padding="16dp"
                    android:background="@color/light_gray"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_search_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_unselected"
        app:itemTextColor="@color/nav_unselected"
        app:itemActiveIndicatorStyle="@android:color/transparent"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>